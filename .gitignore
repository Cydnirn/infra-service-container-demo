# .gitignore

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars

# Terraform lock file — committed, do not ignore
!.terraform.lock.hcl

# Node / React Router
frontend/node_modules/
frontend/build/
frontend/.react-router/

# Go
backend/server

# IDE
.idea/
.vscode/
*.swp
*.swo
Changes.md
Task.md
